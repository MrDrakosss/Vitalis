{
  "schemaVersion": 1,
  "id": "vitalis",
  "version": "${version}",
  "name": "Vitalis",
  "description": "Surgery table mod with injury holograms and orbit camera",
  "authors": [
    "Xavi"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/vitalis/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "me.xavi.vitalis.client.VitalisDataGenerator"
    ],
    "client": [
      "me.xavi.vitalis.client.VitalisClient"
    ],
    "main": [
      "me.xavi.vitalis.Vitalis"
    ]
  },
  "mixins": [
    "vitalis.mixins.json",
    {
      "config": "vitalis.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
